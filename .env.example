# Server port
PORT=3000

# Sync/async threshold in bytes (default 25 MB): at or below → streamed & counted
# in-request; above → async pipeline. Also the sync path's mid-stream cap (413).
MAX_UPLOAD_BYTES=26214400

# Absolute cap for the async (large-file) path in bytes (default 5 GB → 413)
MAX_ASYNC_UPLOAD_BYTES=5368709120

# ── Object storage (MinIO / S3) ───────────────────────────────────────────
# Endpoint includes the published port; forcePathStyle is required for MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=mp3-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── Redis (BullMQ) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── PostgreSQL ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=mp3
DB_PASSWORD=mp3
DB_NAME=mp3
# DEV ONLY: auto-create/update tables from entities. Use migrations in prod.
DB_SYNCHRONIZE=true
